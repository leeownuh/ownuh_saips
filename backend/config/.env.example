# ============================================================
# Ownuh SAIPS — Environment Configuration Template
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application Database ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ownuh_saips
DB_USER=root
DB_PASS=

# ── Credentials Database (password hashes only) ──────────────
# For local/dev: same as main DB (root). 
# For production: use a restricted user (saips_auth).
DB_AUTH_HOST=127.0.0.1
DB_AUTH_PORT=3306
DB_AUTH_USER=root
DB_AUTH_PASS=

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# ── JWT RSA Keys (set automatically by install.sh / setup.php) ─
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# ── JWT Config ───────────────────────────────────────────────
JWT_ISSUER=ownuh-saips
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ADMIN_REFRESH_TTL=28800

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost
BCRYPT_COST=12

# ── MFA ──────────────────────────────────────────────────────
MFA_TOTP_ISSUER=OwnuhSAIPS
MFA_EMAIL_OTP_TTL=600
MFA_EMAIL_OTP_RATE=5
