# ============================================================
# Ownuh SAIPS — Environment Configuration Template
# Copy to backend/config/.env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application Database ──────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ownuh_saips
DB_USER=root
DB_PASS=

# ── Credentials Database (password hashes, isolated) ─────────
DB_AUTH_HOST=127.0.0.1
DB_AUTH_PORT=3306
DB_AUTH_NAME=ownuh_credentials
DB_AUTH_USER=root
DB_AUTH_PASS=

# ── Redis (rate limiting + session store) ────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# ── JWT Keys (generated by install.sh or generate_keys.php) ──
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=ownuh-saips
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ADMIN_REFRESH_TTL=28800

# ── Application ───────────────────────────────────────────────
APP_ENV=development          # change to: production
APP_URL=http://localhost:8080 # change to your public URL or ngrok URL
APP_TIMEZONE=Asia/Kolkata
APP_TIMEZONE_LABEL=IST

# ── Security ──────────────────────────────────────────────────
BCRYPT_COST=12

# TRUSTED_PROXY: IP address of your reverse proxy / load balancer.
# Set to "any" when using ngrok, Cloudflare Tunnel, or similar.
# Leave blank for direct connections (no proxy).
# WARNING: setting "any" disables IP spoofing protection — use only behind a
# real proxy where clients cannot forge X-Forwarded-For.
TRUSTED_PROXY=

# COOKIE_SAMESITE: override cookie SameSite policy.
# "Strict" = most secure, direct connections only.
# "Lax"    = required when app is accessed via ngrok / reverse proxy tunnel.
# Leave blank to auto-detect based on TRUSTED_PROXY.
COOKIE_SAMESITE=

# ── MFA ───────────────────────────────────────────────────────
MFA_TOTP_ISSUER=OwnuhSAIPS
MFA_EMAIL_OTP_TTL=600
MFA_EMAIL_OTP_RATE=5
