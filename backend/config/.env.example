# ============================================================
# Ownuh SAIPS - Environment Configuration Template
# Copy to backend/config/.env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application identity
APP_NAME=Ownuh SAIPS
APP_ENV=production
APP_URL=https://saips.example.com
APP_TIMEZONE=Asia/Kolkata
APP_TIMEZONE_LABEL=IST

# Recruiter / portfolio demo mode
# Keeps the core app in production mode while enabling a friendly
# Demo vs Production experience chooser and demo-only UX helpers.
DEMO_MODE=0

# Main application database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ownuh_saips
DB_USER=saips_app
DB_PASS=change_me_main_db_password

# Credentials database
DB_AUTH_HOST=127.0.0.1
DB_AUTH_PORT=3306
DB_AUTH_NAME=ownuh_credentials
DB_AUTH_USER=saips_auth
DB_AUTH_PASS=change_me_auth_db_password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# JWT
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=ownuh-saips
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ADMIN_REFRESH_TTL=28800

# Security
BCRYPT_COST=14

# TRUSTED_PROXY:
# Set to "any" when using ngrok or another trusted reverse proxy.
# Leave blank for direct local access.
TRUSTED_PROXY=

# GeoIP (optional)
# If provided, GeoLite2 City DB is used for local region/country lookups.
# Example path: backend/data/GeoLite2-City.mmdb
GEOIP_DB_PATH=
# Fallback HTTP provider if GeoLite2 is not configured: ip-api or ipapi
GEOIP_PROVIDER=ip-api
GEOIP_HTTP_TIMEOUT=2

# COOKIE_SAMESITE:
# Use "Lax" when the app is accessed through ngrok or another tunnel.
# Leave blank to let the app choose automatically.
COOKIE_SAMESITE=Strict

# AI reporting
# Use OpenAI or another OpenAI-compatible provider such as Groq.
OPENAI_API_KEY=your_provider_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# MFA
MFA_TOTP_ISSUER=OwnuhSAIPS
MFA_EMAIL_OTP_TTL=600
MFA_EMAIL_OTP_RATE=5

# Email delivery
# Supported providers in this app: smtp, sendgrid
EMAIL_PROVIDER=sendgrid
EMAIL_FROM_NAME=Ownuh SAIPS
EMAIL_FROM_EMAIL=security@ownuh-saips.com
EMAIL_REPLY_TO=security@ownuh-saips.com
SENDGRID_API_KEY=your_sendgrid_api_key_here
